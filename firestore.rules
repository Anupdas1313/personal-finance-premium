rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure the 'users' collection and all of its sub-collections
    match /users/{userId} {
      
      // The user can read and modify their own root document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // The user can read and modify ANY document in any of their sub-collections
      // (accounts, transactions, categories, budgets, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Firestore implicitly denies all access by default to any paths not explicitly matched above.
  }
}
