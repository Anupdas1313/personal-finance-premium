rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match any document in the users collection
    match /users/{userId} {
      // Allow read/write to the user root document if authenticated and UID matches
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Match any subcollection inside the user's folder (e.g. accounts, transactions, etc.)
      match /{document=**} {
        // Allow full read/write access to all data nested inside the user's folder
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Explicitly deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
